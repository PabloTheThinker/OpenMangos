{
  "name": "openmangos",
  "version": "0.10.3",
  "description": "Adaptive terminal framework — senses your environment, adapts to the problem, orchestrates any AI backend",
  "type": "module",
  "bin": {
    "om": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --import tsx --test src/test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "terminal",
    "ai",
    "agent",
    "cli",
    "adaptive",
    "openmangos"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "picocolors": "^1.1.1",
    "ws": "^8.21.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "files": [
    "dist"
  ]
}
